# Auto detect text files and normalize line endings to LF
* text=auto

# PHP files
*.php text eol=lf
*.phtml text eol=lf
*.php3 text eol=lf
*.php4 text eol=lf
*.php5 text eol=lf
*.php7 text eol=lf
*.php8 text eol=lf

# Configuration files
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env text eol=lf
*.env.example text eol=lf

# JavaScript/Node files
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Binary files
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
