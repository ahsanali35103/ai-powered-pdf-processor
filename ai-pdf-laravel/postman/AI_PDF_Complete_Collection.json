								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"user_id\": \"{{user_id}}\",\n    \"organization_name\": \"{{organization_name}}\",\n    \"file_id\": \"{{file_id}}\",\n    \"services\": [\n        {\n            \"type\": \"ocr\"\n        },\n        {\n            \"type\": \"summarization\"\n        }\n    ]\n}"
