					"name": "Complete Workflow - OCR + Summarization",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// This test requires a file to be uploaded first",
									"if (!pm.environment.get('file_id')) {",
									"    console.log('⚠️ Please upload a file first using the File Upload endpoint');",
									"}"
								],
								"type": "text/javascript"
