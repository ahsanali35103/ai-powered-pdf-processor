{
	"info": {
		"_postman_id": "ai-pdf-complete-collection",
		"name": "AI PDF Processing - Complete Collection",
		"description": "Complete API collection for AI PDF processing system including Authentication, File Management, Service Processing, and Worker Testing endpoints.",
