  "test_scenarios": [
    {
      "name": "Complete Workflow Test",
      "steps": [
        "Register new user",
        "Verify email address", 
        "Login to get access token",
        "Upload PDF document",
        "Create OCR service",
        "Wait for processing completion",
        "Create summarization service",
        "Create translation service (Spanish)",
        "Check all service results",
        "List user services with filters"
      ]
    },
    {
      "name": "Multi-User Organization Test",
      "steps": [
        "Register multiple users for same organization",
        "Each user uploads different files",
        "Create various services for each file",
        "Verify organization-level service listing",
        "Test cross-user access restrictions"
      ]
    },
    {
      "name": "Error Handling Test",
      "steps": [
        "Try uploading unsupported file format",
        "Test file size limit (>20MB)",
        "Attempt unauthorized access to other user's files",
        "Create service with missing required fields",
        "Test invalid service types",
        "Verify rate limiting enforcement"
      ]
    },
    {
      "name": "Performance Test",
      "steps": [
        "Upload maximum size file (20MB)",
        "Create multiple concurrent services",
        "Test bulk service listing",
        "Measure response times",
        "Monitor system resource usage"
      ]
    }
  ],
  
  "api_endpoints": {
    "authentication": [
      {
        "method": "POST",
        "endpoint": "/api/auth/signup",
        "description": "Register new user account"
      },
      {
        "method": "POST", 
        "endpoint": "/api/auth/verify-signup",
        "description": "Verify user email address"
      },
      {
        "method": "POST",
        "endpoint": "/api/auth/login", 
        "description": "User login and token generation"
      },
      {
        "method": "POST",
        "endpoint": "/api/auth/logout",
        "description": "User logout and token revocation"
      },
      {
        "method": "POST",
        "endpoint": "/api/auth/forgot-password",
        "description": "Send password reset email"
      },
      {
        "method": "POST",
        "endpoint": "/api/auth/reset-password",
        "description": "Reset password with token"
      }
    ],
    "file_management": [
      {
        "method": "POST",
        "endpoint": "/api/file/upload",
        "description": "Upload PDF or image file"
      },
      {
        "method": "DELETE", 
        "endpoint": "/api/file/delete",
        "description": "Delete uploaded file"
      }
    ],
    "service_processing": [
      {
        "method": "POST",
        "endpoint": "/api/service/create",
        "description": "Create new processing service"
      },
      {
        "method": "GET",
        "endpoint": "/api/service/read", 
        "description": "Get services for specific file"
      },
      {
        "method": "GET",
        "endpoint": "/api/service/list",
        "description": "List all user services with filters"
      }
    ]
  },
  
